#1330 두 수 비교하기
#두 정수 A와 B가 주어졌을 때, A와 B를 비교하는 프로그램을 작성하시오.
# s.t. time : 1sec, memory : 512MB

import sys
A, B = map(int, sys.stdin.readline().split())
if -10000 <= A and B <= 10000 :
    if A > B :
        a = ">"
    elif A < B :
        a = "<"
    else :
        a = "=="

else :
    pass

print(a)